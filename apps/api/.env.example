NODE_ENV=development
PORT=4000

# lowdb or mongo
DB_TYPE=lowdb
LOWDB_PATH=./data/api.json
# MONGO_URI=mongodb://localhost:27017/fusion_api

# Must match the value in auth-api
AUTH_API_GRPC_ADDRESS=localhost:50051

# Must be at least 32 random characters — must match auth-api value
SERVICE_JWT_SECRET=replace-with-at-least-32-random-chars-here

ALLOWED_CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=info
