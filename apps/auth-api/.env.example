NODE_ENV=development
PORT=4001
GRPC_PORT=50051

# Must be at least 64 random characters — generate with: openssl rand -hex 64
SESSION_SECRET=replace-with-at-least-64-random-chars-here-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SESSION_TTL_SECONDS=86400
SESSION_COOKIE_NAME=sid

# lowdb or mongo
DB_TYPE=lowdb
LOWDB_PATH=./data/auth.json
# MONGO_URI=mongodb://localhost:27018/fusion_auth

REDIS_URL=redis://:redispassword@localhost:6379

# Must be at least 32 random characters — generate with: openssl rand -hex 32
SERVICE_JWT_SECRET=replace-with-at-least-32-random-chars-here

ALLOWED_CORS_ORIGINS=http://localhost:5173,http://localhost:5174
LOG_LEVEL=info
