{
  "name": "@fusion-d/proto",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "proto:generate": "node scripts/generate.js",
    "build": "tsup && node -e \"import('fs').then(fs => fs.cpSync('proto', 'dist/proto', { recursive: true }))\"",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.5",
    "@grpc/proto-loader": "^0.7.15"
  },
  "devDependencies": {
    "grpc-tools": "^1.13.0",
    "ts-proto": "^2.6.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
